---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const journalEntries = (await getCollection('journal', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);

const photos = (await getCollection('photos'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);
---

<Layout
	title="Shichen | Journal, photos, and work in progress"
	description="A blog-first personal site with selected writing, photos, and experience."
>
	<section class="hero">
		<div class="hero-copy">
			<p class="eyebrow">Personal site</p>
			<h1>Writing first, then the traces around it.</h1>
			<p class="hero-lede">
				I am Shichen. This is where I collect journal entries, selected photographs, and the
				experience that shaped both.
			</p>
			<div class="hero-actions">
				<a class="button-primary" href="/journal">Read the journal</a>
				<a class="button-secondary" href="/about">About me</a>
			</div>
		</div>

		<div class="hero-card">
			<p class="card-label">Currently</p>
			<p class="card-title">Building a quieter corner of the web.</p>
			<p class="card-body">
				A personal publishing space for notes on work, memory, images, and whatever feels worth
				keeping.
			</p>
		</div>
	</section>

	<section class="panel-grid">
		<article class="panel panel-large">
			<p class="eyebrow">About</p>
			<h2>A compact introduction with room for more later.</h2>
			<p>
				My work sits between curiosity, making, and reflection. I care about thoughtful systems,
				clear writing, and images that preserve atmosphere instead of just information.
			</p>
			<a class="text-link" href="/about">Open my profile</a>
		</article>

		<article class="panel accent-panel">
			<p class="eyebrow">Experience</p>
			<h2>Education, projects, and the timeline behind them.</h2>
			<p>From study to hands-on building, this page keeps the longer arc visible.</p>
			<a class="text-link" href="/experience">View timeline</a>
		</article>
	</section>

	<section class="section-header">
		<div>
			<p class="eyebrow">Latest journal</p>
			<h2>Recent entries</h2>
		</div>
		<a class="section-link" href="/journal">All posts</a>
	</section>

	<section class="post-list">
		{
			journalEntries.map((entry) => (
				<a class="post-card" href={`/journal/${entry.id}/`}>
					<p class="meta">{entry.data.date.toLocaleDateString('en-US', { dateStyle: 'long' })}</p>
					<h3>{entry.data.title}</h3>
					<p>{entry.data.summary}</p>
					{entry.data.tags && (
						<ul class="tag-list" aria-label="Tags">
							{entry.data.tags.map((tag) => (
								<li>{tag}</li>
							))}
						</ul>
					)}
				</a>
			))
		}
	</section>

	<section class="section-header">
		<div>
			<p class="eyebrow">Selected photos</p>
			<h2>Light studies and travel fragments</h2>
		</div>
		<a class="section-link" href="/photos">Photo page</a>
	</section>

	<section class="photo-grid">
		{
			photos.map((photo) => (
				<article class="photo-card">
					<img src={photo.data.image.src} alt={photo.data.caption || photo.data.title} loading="lazy" />
					<div class="photo-copy">
						<h3>{photo.data.title}</h3>
						<p>{photo.data.caption}</p>
					</div>
				</article>
			))
		}
	</section>
</Layout>
