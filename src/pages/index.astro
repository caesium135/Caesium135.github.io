---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const journalEntries = (await getCollection('journal', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);

const news = [
	{
		date: 'Mar 2026',
		text: 'Launched this personal website as a home for updates, writing, and research notes.',
	},
	{
		date: 'Feb 2026',
		text: 'Started a new undergraduate research role in Murphy’s Group focused on website tooling, autonomous image processing, and nanoparticle analysis on noisy TEM/STEM images.',
	},
	{
		date: 'Feb 2025',
		text: 'Joined Murphy’s Group as an undergraduate research assistant on nanoparticle synthesis, functionalization, and characterization.',
	},
];
---

<Layout
	title="Shi Chen"
	description="Shi Chen is an undergraduate at UIUC studying Computer Science and Chemistry."
>
	<section class="profile-section">
		<div class="profile-photo profile-photo-placeholder" aria-label="Profile photo placeholder">
			<span>Photo</span>
		</div>
		<div class="profile-copy">
			<h1>Shi Chen</h1>
			<p class="profile-meta">
				B.S. in Computer Science + Chemistry, University of Illinois Urbana-Champaign
			</p>
			<div class="contact-links">
				<a href="mailto:shic4@illinois.edu">shic4@illinois.edu</a>
				<span>/</span>
				<a href="https://github.com/Caesium135">GitHub</a>
				<span>/</span>
				<span>Champaign, IL</span>
			</div>
			<p class="bio" id="about">
				I am an undergraduate student at the University of Illinois Urbana-Champaign studying
				Computer Science and Chemistry. My interests are in machine learning, scientific tools,
				and computational methods for analyzing complex experimental data. I am currently working
				with Murphy’s Group on research projects spanning nanoparticle analysis, image processing,
				and chemistry-driven experimentation.
			</p>
			<p class="bio">
				Previously, I worked on synthesis, functionalization, and characterization of gold
				nanoparticles, while building stronger foundations across algorithms, machine learning,
				and applied computing.
			</p>
		</div>
	</section>

	<section class="section-block" id="experience">
		<h2>Experience</h2>
		<div class="entry-list">
			<article class="entry-item">
				<div class="entry-heading">
					<h3>University of Illinois Urbana-Champaign</h3>
					<p>Champaign, IL</p>
				</div>
				<p class="entry-subtitle">B.S. in Computer Science + Chemistry, Class of 2028</p>
				<p class="entry-meta-line">GPA: 4.0/4.0 · Dean’s List: Fall 2024, Spring 2025, Fall 2025</p>
				<p>
					Relevant coursework includes Data Structures, Algorithms & Models of Computation,
					Machine Learning, Linear Algebra for Computational Applications, Probability &
					Statistics for Computer Science, and advanced chemistry coursework.
				</p>
			</article>

			<article class="entry-item">
				<div class="entry-heading">
					<h3>Murphy’s Group, University of Illinois</h3>
					<p>Feb 2026 – May 2026</p>
				</div>
				<p class="entry-subtitle">Undergraduate Research Assistant (Instrumental focus)</p>
				<p>
					Building a website tool for rod sizing with autonomous image processing and machine
					learning methods for nanoparticle analysis on noisy TEM/STEM images, in collaboration
					with Arda Turk.
				</p>
			</article>

			<article class="entry-item">
				<div class="entry-heading">
					<h3>Murphy’s Group, University of Illinois</h3>
					<p>Feb 2025 – Feb 2026</p>
				</div>
				<p class="entry-subtitle">Undergraduate Research Assistant (Experimental focus)</p>
				<p>
					Worked on synthesis, functionalization, and characterization of AuNPs, including a
					project on cyanide etching on 13nm AuNS with ligands of different surface charges, and
					supported data analysis and visualization for Cu@AuNR CO2 reduction catalysis work.
				</p>
			</article>
		</div>
	</section>

	<section class="section-block" id="news">
		<h2>News</h2>
		<ul class="news-list">
			{
				news.map((item) => (
					<li>
						<span class="news-date">{item.date}</span>
						<span>{item.text}</span>
					</li>
				))
			}
		</ul>
	</section>

	<section class="section-block" id="posts">
		<div class="section-header">
			<h2>Posts</h2>
			<a href="/posts">All posts</a>
		</div>
		<ul class="post-list-simple">
			{
				journalEntries.map((entry) => (
					<li>
						<span class="post-date">
							{entry.data.date.toLocaleDateString('en-US', { dateStyle: 'medium' })}
						</span>
						<a href={`/posts/${entry.id}/`}>{entry.data.title}</a>
					</li>
				))
			}
		</ul>
	</section>
</Layout>
