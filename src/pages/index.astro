---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Shi Chen"
	description="Shi Chen is an undergraduate at UIUC studying Computer Science and Chemistry."
>
	<section class="profile-section">
		<img class="profile-photo" src="/profile.jpg" alt="Shi Chen" />
		<div class="profile-copy">
			<h1>Shi Chen</h1>
			<div class="contact-links">
				<span>shic4 [at] illinois [dot] edu</span>
				<span>/</span>
				<a href="https://github.com/Caesium135">GitHub</a>
			</div>
			<p class="bio">
				I am a Computer Science + Chemistry undergraduate at the University of Illinois
				Urbana-Champaign interested in machine learning, scientific tools, and computational
				methods for experimental data.
			</p>
			<div class="experience-compact">
				<h2>Education</h2>
				<div class="entry-list">
					<article class="entry-item">
						<div class="entry-heading">
							<h3>University of Illinois at Urbana-Champaign</h3>
							<p>Class of 2028</p>
						</div>
						<p>
							Bachelor of Science in Computer Science + Chemistry. GPA: 4.0/4.0. Dean’s
							List: Fall 2024, Spring 2025, Fall 2025.
						</p>
					</article>
				</div>
			</div>
			<div class="experience-compact">
				<h2>Experience</h2>
				<div class="entry-list">
					<article class="entry-item">
						<div class="entry-heading">
							<h3>Murphy’s Group, University of Illinois</h3>
							<p>Feb 2025 – May 2026</p>
						</div>
						<p>
							Undergraduate Research Assistant working on synthesis, functionalization and
							characterization of AuNP, and building a website tool for rod sizing featuring
							autonomous image processing and nanoparticle analysis on noisy TEM/STEM images
							through machine learning methods.
						</p>
					</article>
				</div>
			</div>
		</div>
	</section>

	<section class="section-block" id="news">
		<h2>News</h2>
		<p class="empty-state">No updates yet.</p>
	</section>

	<section class="section-block" id="posts">
		<div class="section-header">
			<h2>Posts</h2>
			<a href="/posts">All posts</a>
		</div>
		<p class="empty-state">No posts yet.</p>
	</section>
</Layout>
