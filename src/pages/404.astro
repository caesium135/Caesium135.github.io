---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not found | Shichen" description="The page you requested could not be found.">
	<section class="listing-hero">
		<p class="eyebrow">404</p>
		<h1>This page drifted out of frame.</h1>
		<p class="listing-copy">The link may be outdated, or the page has been moved.</p>
		<a class="button-primary" href="/">Return home</a>
	</section>
</Layout>
