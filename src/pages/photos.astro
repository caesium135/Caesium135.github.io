---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const photos = (await getCollection('photos')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Photos | Shichen" description="A small gallery of selected photographs and captions.">
	<section class="listing-hero">
		<p class="eyebrow">Photos</p>
		<h1>A small gallery of places, weather, and passing light.</h1>
		<p class="listing-copy">
			These are not meant to be exhaustive. They are markers of mood, movement, and the shape of
			a day.
		</p>
	</section>

	<section class="gallery-grid">
		{
			photos.map((photo) => (
				<article class="gallery-card">
					<img src={photo.data.image.src} alt={photo.data.caption || photo.data.title} loading="lazy" />
					<div class="gallery-copy">
						<div>
							<p class="meta">{photo.data.date.toLocaleDateString('en-US', { dateStyle: 'long' })}</p>
							<h2>{photo.data.title}</h2>
						</div>
						<p>{photo.data.caption}</p>
						{photo.data.location && <p class="location">{photo.data.location}</p>}
					</div>
				</article>
			))
		}
	</section>
</Layout>
