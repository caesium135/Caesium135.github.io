---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const entries = (await getCollection('journal', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout title="Journal | Shichen" description="Journal entries and notes by Shichen.">
	<section class="listing-hero">
		<p class="eyebrow">Journal</p>
		<h1>Notes, fragments, and longer entries.</h1>
		<p class="listing-copy">
			The journal is the center of the site. It is where finished thoughts and unfinished ones
			can stay in the same room.
		</p>
	</section>

	<section class="post-list">
		{
			entries.map((entry) => (
				<a class="post-card" href={`/journal/${entry.id}/`}>
					<p class="meta">{entry.data.date.toLocaleDateString('en-US', { dateStyle: 'long' })}</p>
					<h2>{entry.data.title}</h2>
					<p>{entry.data.summary}</p>
					{entry.data.tags && (
						<ul class="tag-list" aria-label="Tags">
							{entry.data.tags.map((tag) => (
								<li>{tag}</li>
							))}
						</ul>
					)}
				</a>
			))
		}
	</section>
</Layout>
